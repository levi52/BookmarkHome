{
  "manifest_version": 3,
  "name": "BookmarkHome — 收藏夹主页",
  "version": "1.5.0",
  "description": "将浏览器收藏夹分类展示为精美的新标签页主页，支持搜索、分组折叠和快速跳转。",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "bookmarks",
    "storage",
    "tabs",
    "favicon"
  ],
  "chrome_url_overrides": {
    "newtab": "newtab/newtab.html"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "BookmarkHome"
  },
  "background": {
    "service_worker": "background/background.js"
  }
}
